#!/bin/sh
set -eu

CONFIGURED_IFACE="{{ detected_lte_iface }}"
LTE_IP="{{ lte_ip }}"
LTE_NET="{{ lte_network }}"
LTE_GW="{{ lte_gateway }}"
TABLE="{{ lte_table }}"
PRIORITY="{{ lte_rule_priority }}"
WIFI_IFACE="{{ wifi_iface }}"

find_lte_iface() {
    if [ -n "$CONFIGURED_IFACE" ] && [ -d "/sys/class/net/$CONFIGURED_IFACE" ]; then
        printf '%s\n' "$CONFIGURED_IFACE"
        return 0
    fi

    for net_path in /sys/class/net/*; do
        [ -e "$net_path/device/driver" ] || continue
        driver="$(basename "$(readlink -f "$net_path/device/driver")")"
        if [ "$driver" = "qmi_wwan" ]; then
            basename "$net_path"
            return 0
        fi
    done

    return 1
}

IFACE=""
for _attempt in $(seq 1 180); do
    IFACE="$(find_lte_iface || true)"
    if [ -n "$IFACE" ] && ip -4 addr show dev "$IFACE" 2>/dev/null | grep -Fq "$LTE_IP"; then
        break
    fi
    sleep 1
done

if [ -z "$IFACE" ] || ! ip -4 addr show dev "$IFACE" 2>/dev/null | grep -Fq "$LTE_IP"; then
    echo "LTE policy routing failed: address $LTE_IP did not appear on a qmi_wwan interface" >&2
    exit 1
fi

sysctl -w net.ipv4.conf.all.rp_filter=0 >/dev/null
sysctl -w net.ipv4.conf.default.rp_filter=0 >/dev/null
sysctl -w "net.ipv4.conf.$IFACE.rp_filter=0" >/dev/null
sysctl -w "net.ipv4.conf.$WIFI_IFACE.rp_filter=0" >/dev/null 2>&1 || true

ip -4 route replace "$LTE_NET" dev "$IFACE" src "$LTE_IP" table "$TABLE"
ip -4 route replace default via "$LTE_GW" dev "$IFACE" table "$TABLE"

matching_rules="$(ip -4 rule show | grep -Ec "from ${LTE_IP}(/32)? (lookup|table) ${TABLE}" || true)"
priority_rules="$(ip -4 rule show | grep -Ec "^${PRIORITY}:.*from ${LTE_IP}(/32)? (lookup|table) ${TABLE}" || true)"
if [ "$matching_rules" -ne 1 ] || [ "$priority_rules" -ne 1 ]; then
    while ip -4 rule delete from "$LTE_IP/32" table "$TABLE" >/dev/null 2>&1; do
        :
    done
    ip -4 rule add priority "$PRIORITY" from "$LTE_IP/32" table "$TABLE"
fi

ip -4 route get 1.1.1.1 from "$LTE_IP"
